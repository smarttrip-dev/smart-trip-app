NODE_ENV=production
PORT=5001

# MongoDB Atlas connection string
MONGO_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/smart-trip?retryWrites=true&w=majority

# JWT secret (use a long random string)
JWT_SECRET=your_super_secret_jwt_key_here

# Your Railway service URL (set after first deploy, allows CORS from same origin)
CORS_ORIGIN=https://your-app.up.railway.app
